# --- Database ---
# Se non impostato o non raggiungibile, il backend usa uno store in-memory (solo dev).
MONGO_URL=mongodb://localhost:27017
DB_NAME=ftmo_app

# --- AI (Emergent LLM Key) ---
# Chiave universale Emergent per Claude Sonnet 4.5. Se assente, l'app usa il
# template locale (modalità "Locale") come fallback automatico.
EMERGENT_LLM_KEY=
# Modello AI usato per la generazione strategia
AI_MODEL=claude-sonnet-4-5
# Endpoint compatibile (Emergent integrations gateway). Override se necessario.
EMERGENT_BASE_URL=https://llm.emergent.sh/v1

# --- Server ---
CORS_ORIGINS=*
PORT=8000
